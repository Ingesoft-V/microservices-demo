# External Configuration Store (copy to .env)
# cp .env.example .env

# PostgreSQL
POSTGRES_USER=okteto
POSTGRES_PASSWORD=okteto
POSTGRES_DB=votes

# Kafka
KAFKA_EXTERNAL_PORT=9092
KAFKA_INTERNAL_PORT=29092
KAFKA_TOPIC=votes
KAFKA_TOPIC_PARTITIONS=3
KAFKA_GROUP=voting-group

# App ports
VOTE_EXTERNAL_PORT=5000
RESULT_EXTERNAL_PORT=5001

# Result polling
RESULT_POLL_INTERVAL_MS=1000
RESULT_DB_RETRY_TIMES=1000
RESULT_DB_RETRY_INTERVAL_MS=1000

# Vote options
OPTION_A=Burritos
OPTION_B=Tacos
